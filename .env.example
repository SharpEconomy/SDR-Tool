APP_NAME=Growth Opportunity Decision Engine
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRY_ATTEMPTS=2
REQUEST_RETRY_BACKOFF_SECONDS=1
SMTP_TIMEOUT_SECONDS=10
MAX_FETCH_WORKERS=6
MAX_VALIDATION_WORKERS=4
MAX_RESULTS_PER_ADAPTER=5
MAX_OPPORTUNITIES=25
MAX_LLM_REFINEMENTS=10
USE_BROWSER_FALLBACK=true
SMTP_PROBE_ENABLED=false
MIN_EMAIL_VALIDATION_SCORE=2

OPENAI_ENABLED=true
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

GOOGLE_SEARCH_API_KEY=replace-with-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=replace-with-search-engine-id

AUDIT_BACKEND=firestore
FIRESTORE_COLLECTION=growth_engine_runs
FIRESTORE_PROFILE_COLLECTION=growth_engine_profiles
FIRESTORE_DATABASE=growth-opportunity

GOOGLE_CLOUD_PROJECT=replace-with-project-id
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON_B64=replace-with-base64-service-account-json

DEFAULT_DISCOVERY_MODES=customers,partners
DEFAULT_TARGET_GEOGRAPHIES=India,United States

FIREBASE_API_KEY=replace-with-firebase-api-key
FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app

DJANGO_SECRET_KEY=replace-with-django-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost
